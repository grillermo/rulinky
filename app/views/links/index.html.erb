<main class="min-h-screen bg-gray-100 text-gray-900 font-sans p-4 flex flex-col items-center">
  <div class="bg-white rounded-lg shadow-lg p-6 w-full max-w-md">
    <header class="text-center justify-center">
      <img
        src="https://guillermo-public.s3.us-east-1.amazonaws.com/file-to-s3-uploads/9253d692-d691-4b84-83e3-766c1b99f39b-Image.png?v=20260405"
        alt="Rulinky logo"
        width="120"
        height="40"
        class="h-auto w-auto inline-block"
      />
    </header>

    <div>
      <div class="flex p-1 bg-gray-100 rounded-lg mb-6 top-2 z-10 backdrop-blur-sm">
        <a
          href="/"
          class="pl-3 flex-1 py-2 text-sm font-medium rounded-md transition-all hover:cursor-pointer <%= @filter == 'unread' ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>"
        >
          Unread <span id="unread-links-count"><%= @unread_links_count %></span>
        </a>
        <a
          href="/?filter=read"
          class="pl-3 flex-1 py-2 text-sm font-medium rounded-md transition-all hover:cursor-pointer <%= @filter == 'read' ? 'bg-white text-gray-900 shadow-sm' : 'text-gray-500 hover:text-gray-700' %>"
        >
          Read <span id="read-links-count"><%= @read_links_count %></span>
        </a>
      </div>

      <div class="space-y-1 min-h-[50vh]">
        <% if @filtered_links.empty? %>
          <div class="text-center py-12 text-gray-500">
            <p>No links found.</p>
          </div>
        <% else %>
          <% @filtered_links.each do |link| %>
            <% read = link.read.to_i == 1 %>
            <a
              href="<%= link.url %>"
              target="_blank"
              rel="noopener noreferrer"
              data-link-id="<%= link.id %>"
              data-link-read="<%= read ? 1 : 0 %>"
              class="block p-4 mb-3 rounded-xl border border-blue-200 transition-all active:scale-[0.98] cursor-pointer text-inherit no-underline hover:cursor-pointer <%= read ? 'bg-gray-100 opacity-60' : '' %>"
            >
              <div class="flex justify-between items-start gap-3">
                <div class="flex-1 min-w-0">
                  <h3 class="text-lg font-medium text-gray-900 break-all whitespace-normal">
                    <%= display_url_without_scheme(link.url) %>
                  </h3>
                </div>
                <div class="flex shrink-0 flex-col items-center gap-2">
                  <button
                    type="button"
                    class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-red-200 bg-red-50 text-sm transition-colors hover:bg-red-100"
                    title="Delete link"
                    aria-label="Delete link"
                    onclick="handleDelete(event, '<%= link.id %>')"
                  >
                    🗑️
                  </button>
                  <button
                    type="button"
                    class="inline-flex h-8 w-8 items-center justify-center rounded-full border border-blue-200 bg-blue-50 text-sm transition-colors hover:bg-blue-100"
                    data-role="toggle-read"
                    title="<%= read ? 'Mark as unread' : 'Mark as read' %>"
                    aria-label="<%= read ? 'Mark as unread' : 'Mark as read' %>"
                    onclick="<%= read ? "handleUnread(event, '#{link.id}')" : "handleRead(event, '#{link.id}')" %>"
                  >
                    <%= read ? "📩" : "✅" %>
                  </button>
                </div>
              </div>
              <div class="mt-2 text-xs text-gray-400">
                <%= ms_to_local_time_string(link.updated_at) %>
              </div>
            </a>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</main>

<script>
  function handleDelete(event, id) {
    event.preventDefault();
    event.stopPropagation();
    submitDeleteForm(id);
  }

  function handleUnread(event, id) {
    event.preventDefault();
    event.stopPropagation();
    submitUnreadForm(id, event.currentTarget);
  }

  function handleRead(event, id) {
    event.preventDefault();
    event.stopPropagation();
    submitReadForm(id, event.currentTarget);
  }

  function submitDeleteForm(id) {
    var form = document.createElement('form');
    form.method = 'post';
    form.action = '/links/' + id;
    var hiddenMethod = document.createElement('input');
    hiddenMethod.type = 'hidden';
    hiddenMethod.name = '_method';
    hiddenMethod.value = 'delete';
    form.appendChild(hiddenMethod);
    
    var csrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
    if (csrfTokenMeta) {
      var csrfInput = document.createElement('input');
      csrfInput.type = 'hidden';
      csrfInput.name = 'authenticity_token';
      csrfInput.value = csrfTokenMeta.content;
      form.appendChild(csrfInput);
    }
    
    document.body.appendChild(form);
    form.submit();
  }

  function submitUnreadForm(id, button) {
    updateReadStatus(id, false, button);
  }

  function submitReadForm(id, button) {
    updateReadStatus(id, true, button);
  }

  function updateReadStatus(id, read, button) {
    if (!button || button.disabled) return;

    var csrfTokenMeta = document.querySelector('meta[name="csrf-token"]');
    var csrfToken = csrfTokenMeta ? csrfTokenMeta.content : '';
    var row = button.closest('a[data-link-id]');
    if (!row) return;

    button.disabled = true;

    fetch('/links/' + id + '/' + (read ? 'read' : 'unread'), {
      method: 'POST',
      headers: {
        'X-CSRF-Token': csrfToken,
        'X-Requested-With': 'XMLHttpRequest'
      },
      body: new URLSearchParams({ _method: 'patch' })
    }).then(function (response) {
      if (!response.ok) throw new Error('Request failed');
      applyReadState(row, button, read);
    }).catch(function () {
      button.disabled = false;
    });
  }

  function applyReadState(row, button, read) {
    row.setAttribute('data-link-read', read ? '1' : '0');
    row.classList.toggle('bg-gray-100', read);
    row.classList.toggle('opacity-60', read);

    button.textContent = read ? '📩' : '✅';
    button.title = read ? 'Mark as unread' : 'Mark as read';
    button.setAttribute('aria-label', read ? 'Mark as unread' : 'Mark as read');
    button.setAttribute('onclick', (read ? 'handleUnread' : 'handleRead') + "(event, '" + row.getAttribute('data-link-id') + "')");
    button.disabled = false;

    updateCounts(read);
  }

  function updateCounts(read) {
    var readCount = document.getElementById('read-links-count');
    var unreadCount = document.getElementById('unread-links-count');
    if (!readCount || !unreadCount) return;

    var readValue = parseInt(readCount.textContent, 10);
    var unreadValue = parseInt(unreadCount.textContent, 10);
    if (isNaN(readValue) || isNaN(unreadValue)) return;

    readCount.textContent = String(read ? readValue + 1 : Math.max(0, readValue - 1));
    unreadCount.textContent = String(read ? Math.max(0, unreadValue - 1) : unreadValue + 1);
  }
</script>
